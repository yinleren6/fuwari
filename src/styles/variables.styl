/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 0
  --content-delay 150ms

/* An util to define variables */
define(vars)
  :root
    for key, value in vars
      {key}: value

define({
  --primary: oklch(0.70 0.15 var(--hue))
  --page-bg: oklch(0.16 0.015 var(--hue))
  --card-bg: oklch(0.20 0.025 var(--hue))
  --card-bg-transparent: unquote("rgba(from oklch(0.20 0.025 var(--hue)) r g b / 0.8)")

  --btn-content: oklch(0.75 0.15 var(--hue))

  --btn-regular-bg: oklch(0.41 0.12 var(--hue))
  --btn-regular-bg-hover: oklch(0.48 0.15 var(--hue))
  --btn-regular-bg-active: oklch(0.57 0.18 var(--hue))

  --btn-plain-bg-hover: unquote("rgba(from oklch(0.41 0.12 var(--hue)) r g b / 0.3)")
  --btn-plain-bg-active: unquote("rgba(from oklch(0.48 0.15 var(--hue)) r g b / 0.5)")

  --btn-card-bg-hover: unquote("rgba(from oklch(0.41 0.12 var(--hue)) r g b / 0.15)")
  --btn-card-bg-active: unquote("rgba(from oklch(0.48 0.15 var(--hue)) r g b / 0.3)")

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.75 0.03 var(--hue))

  --title-active: oklch(0.78 0.15 var(--hue))

  --line-divider: white(0.08)

  --line-color: white(0.2)
  --meta-divider: white(0.5)

  --inline-code-bg: oklch(0.27 0.05 var(--hue))
  --inline-code-color: oklch(0.72 0.05 var(--hue))
  --selection-bg: oklch(0.40 0.10 var(--hue))
  --codeblock-selection: oklch(0.27 0.05 var(--hue))
  --codeblock-bg: oklch(0.19 0.02 var(--hue))
  --codeblock-topbar-bg: oklch(0.15 0.02 var(--hue))

  --license-block-bg: var(--codeblock-bg)

  --link-underline: oklch(0.60 0.18 var(--hue))
  --link-hover: oklch(0.70 0.18 var(--hue))
  --link-active: oklch(0.75 0.20 var(--hue))

  --float-panel-bg: oklch(0.19 0.025 var(--hue))
  --float-panel-bg-transparent: unquote("rgba(from oklch(0.19 0.025 var(--hue)) r g b / 0.8)")
  --float-panel-bg-opaque: oklch(0.19 0.025 var(--hue))

  --scrollbar-bg: white(0.4)
  --scrollbar-bg-hover: white(0.5)
  --scrollbar-bg-active: white(0.6)

  --color-selection-bar: rainbow-dark

  --admonitions-color-tip: oklch(0.85 0.12 180)
  --admonitions-color-note: oklch(0.85 0.12 250)
  --admonitions-color-important: oklch(0.85 0.12 310)
  --admonitions-color-warning: oklch(0.85 0.12 60)
  --admonitions-color-caution: oklch(0.75 0.12 25)
  --admonitions-color-ai: oklch(0.85 0.12 280)

  --toc-badge-bg: var(--btn-regular-bg)
  --toc-btn-hover: unquote("rgba(from oklch(0.41 0.12 var(--hue)) r g b / 0.3)")
  --toc-btn-active: unquote("rgba(from oklch(0.48 0.15 var(--hue)) r g b / 0.5)")
  --toc-width: clamp(11rem, calc((100vw - var(--page-width)) / 2 - 1rem), 22rem)
  --toc-item-active: oklch(0.40 0.10 var(--hue))
})
