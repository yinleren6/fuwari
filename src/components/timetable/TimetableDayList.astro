---
import type { TimetableViewModel } from "@/types/timetable";
import TimetableCourseCard from "@components/timetable/TimetableCourseCard.astro";

interface Props {
	viewModel: TimetableViewModel;
}

const { viewModel } = Astro.props;
---

<div class="space-y-4 md:hidden">
	{viewModel.dayColumns.map((day) => {
		const courses = viewModel.coursesByDay[day.day] ?? [];
		return (
			<section class="p-4 border-b border-white/10">
				<h2 class="text-sm font-semibold text-white mb-3">{day.label}</h2>
				{courses.length > 0 ? (
					<div class="space-y-2.5">
						{courses.map((course) => (
							<TimetableCourseCard course={course} showTime={true} />
						))}
					</div>
				) : (
					<p class="text-xs text-white/70">本周暂无课程</p>
				)}
			</section>
		);
	})}
</div>
