---
import type { TimetableViewModel } from "@/types/timetable";
import PageCardHeader from "@components/misc/PageCardHeader.astro";
import LiveTimetableStatus from "@components/timetable/LiveTimetableStatus.astro";
import TimetableDayList from "@components/timetable/TimetableDayList.astro";
import TimetableGrid from "@components/timetable/TimetableGrid.astro";
import TimetableVisualEditor from "@components/timetable/TimetableVisualEditor.svelte";
import Icon from "@components/Icon.astro";

interface Props {
	viewModel: TimetableViewModel;
	isCurrentWeek?: boolean;
	baselineText: string;
}

const { viewModel, isCurrentWeek = false, baselineText } = Astro.props;

const liveStatusPayload = {
	coursesByDay: viewModel.coursesByDay,
};
---

<div class="p-6 md:p-8 border-b border-white/10">
	<PageCardHeader title={viewModel.tableName} icon="material-symbols:calendar-month" pathname="/timetable/">
		<div slot="title-extra" class="text-sm font-medium text-white/80">共 {viewModel.maxWeek} 周</div>
	</PageCardHeader>

	<div class="flex flex-wrap items-center gap-3 mb-5 text-sm">
		<div class="inline-flex items-center gap-1">
			<a
				href={`/timetable/${Math.max(1, viewModel.currentWeek - 1)}/`}
				class:list={[
					"btn-regular h-9 w-9 rounded-lg flex items-center justify-center font-medium",
					{ "pointer-events-none opacity-50": viewModel.currentWeek <= 1 },
				]}
				aria-label="上一周"
			>
				<Icon name="material-symbols:chevron-right-rounded" class="text-[1.25rem] rotate-180" />
			</a>
			<span class="min-w-[4.5rem] px-1 text-center font-medium text-white">第 {viewModel.currentWeek} 周</span>
			<a
				href={`/timetable/${Math.min(viewModel.maxWeek, viewModel.currentWeek + 1)}/`}
				class:list={[
					"btn-regular h-9 w-9 rounded-lg flex items-center justify-center font-medium",
					{ "pointer-events-none opacity-50": viewModel.currentWeek >= viewModel.maxWeek },
				]}
				aria-label="下一周"
			>
				<Icon name="material-symbols:chevron-right-rounded" class="text-[1.25rem]" />
			</a>
			{isCurrentWeek && <span class="rounded-lg border border-emerald-400/30 bg-emerald-500/10 px-2.5 py-1 text-sm font-medium text-emerald-200 leading-none">当前周</span>}
		</div>
	</div>

	<LiveTimetableStatus payload={liveStatusPayload} class="mb-4" />

	<TimetableVisualEditor client:load viewModel={viewModel} baselineText={baselineText} />

	<p class="text-xs text-white/80 mb-4">提示：周次切换后将展示该周实际有课的安排，多周课程会在对应周自动出现。</p>

	<TimetableGrid viewModel={viewModel} />
	<TimetableDayList viewModel={viewModel} />
</div>

