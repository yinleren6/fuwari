---
import ViewsCounter from "@components/ViewsCounter.astro";
import Icon from "@components/Icon.astro";

interface Props {
	title: string;
	icon: string;
	pathname?: string;
	class?: string;
}

const { title, icon, pathname, class: className } = Astro.props;
---

<div class:list={["flex items-center justify-between gap-3 flex-wrap mb-6", className]}>
	<div class="flex items-center gap-2">
		<div class="page-title-icon">
			<Icon name={icon} class="text-[1.5rem]"></Icon>
		</div>
		<h1 class="text-2xl font-bold text-90">{title}</h1>
		<slot name="title-extra" />
		{pathname && <ViewsCounter pathname={pathname} />}
	</div>
	<slot name="actions" />
</div>
