---
import Icon from "@components/Icon.astro";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";

import Search from "./Search.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";
const className = Astro.props.class;

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);
---
<div id="navbar" class="z-50">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)]"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base border-b border-white/10 !overflow-visible max-w-[var(--page-width)] h-[4.5rem] mx-auto flex items-center justify-between px-4"]}>
        <div class="hidden min-[1066px]:flex items-center">
            {links.map((l) => {
                return <a aria-label={l.name} href={l.external ? l.url : url(l.url)} target={l.external ? "_blank" : null}
                          class="btn-plain scale-animation h-11 font-bold px-5 active:scale-95 border-r border-white/10 last:border-r-0"
                >
                    <div class="flex items-center">
                        {l.icon && <Icon name={l.icon} class="text-[1.1rem] mr-1.5" />}
                        {l.name}
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-white/[0.2]"></Icon>}
                    </div>
                </a>;
            })}
        </div>
        <div class="flex flex-1 items-center gap-2 min-[1066px]:flex-none min-[1066px]:gap-0">
            <a aria-label="Home" href={url("/")}
               class="btn-plain scale-animation flex h-11 w-11 items-center justify-center active:scale-90 min-[1066px]:!hidden border border-white/10">
                <Icon name="material-symbols:home-rounded" class="text-[1.25rem]"></Icon>
            </a>
            <!--<SearchPanel client:load>-->
            <Search client:idle></Search>

            <details class="min-[1066px]:!hidden">
                <summary aria-label="Menu" class="btn-plain scale-animation w-11 h-11 active:scale-90 border border-white/10 cursor-pointer">
                    <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
                </summary>
                <NavMenuPanel links={links}></NavMenuPanel>
            </details>
        </div>
    </div>
</div>
